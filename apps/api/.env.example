# --- App ---
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:3000
# Public URL of the web app — used to build invite links in emails. Must
# match where users actually open the app, not the API URL.
APP_BASE_URL=http://localhost:3000

# --- Database (Prisma) ---
DATABASE_URL=postgresql://dvwms:dvwms_local_password@localhost:5432/dvwms?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- JWT ---
JWT_ACCESS_SECRET=replace_me_with_a_long_random_string
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=replace_me_with_a_different_long_random_string
JWT_REFRESH_TTL=7d

# --- Email (transactional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="DV-WMS <no-reply@digitalvetri.com>"

# --- Storage (object storage for uploads) ---
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# --- Scoring engine defaults (also editable via /config/scoring) ---
SCORING_PERIOD_DAYS=30
STALE_LEAD_DAYS=3
REPORT_CUTOFF=19:00
WORK_START_TIME=10:00

# --- AI (Anthropic) ---
# Leave empty to disable AI features (endpoints will return 503).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# --- WhatsApp (Meta Cloud API) ---
# Leave both empty to disable WhatsApp delivery (sends will log instead).
WHATSAPP_META_PHONE_NUMBER_ID=
WHATSAPP_META_ACCESS_TOKEN=
WHATSAPP_META_GRAPH_VERSION=v21.0
