{
  "name": "@dv-wms/types",
  "version": "0.1.0",
  "private": true,
  "description": "Shared TypeScript contracts for DV-WMS (web + api)",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
