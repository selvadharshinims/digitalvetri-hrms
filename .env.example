# Root env. Used by docker-compose for both the infra and `--profile app`
# (api + web) services. App-specific local dev still uses apps/api/.env and
# apps/web/.env.local.

# ─── Infra (Postgres + Redis) ────────────────────────────────────────────────
POSTGRES_USER=dvwms
POSTGRES_PASSWORD=dvwms_local_password
POSTGRES_DB=dvwms
POSTGRES_PORT=5432

REDIS_PORT=6379

# ─── API container (only read when running `--profile app`) ──────────────────
API_PORT=3001
CORS_ORIGIN=http://localhost:3000

# Required — the container will refuse to start without these.
JWT_ACCESS_SECRET=replace_me_with_a_long_random_string
JWT_REFRESH_SECRET=replace_me_with_a_different_long_random_string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Optional — leave empty to log instead of send.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="DV-WMS <no-reply@digitalvetri.com>"

# Optional — leave empty to disable AI features (endpoints return 503,
# scheduled AI jobs skip cleanly).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# Optional — leave empty to log WhatsApp sends instead of dispatching.
WHATSAPP_META_PHONE_NUMBER_ID=
WHATSAPP_META_ACCESS_TOKEN=
WHATSAPP_META_GRAPH_VERSION=v21.0

# ─── Web container (only read when running `--profile app`) ──────────────────
WEB_PORT=3000
# NEXT_PUBLIC_* are baked into the client bundle at `docker build` time.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_APP_NAME=DV-WMS
